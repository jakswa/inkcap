<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= it.title %></title>
    <link rel="icon" href="/assets/<%= it.assetVersion %>/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/assets/<%= it.assetVersion %>/app.css">
  </head>
  <body class="min-h-screen bg-slate-50 font-body text-slate-900 antialiased">
    <%~ include('../partials/header', it) %>
    <main class="mx-auto max-w-5xl px-4 py-[clamp(2rem,8vw,6rem)]">
      <%~ it.body %>
    </main>
    <%~ include('../partials/footer', it) %>
  </body>
</html>
