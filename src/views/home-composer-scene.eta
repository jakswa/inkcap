<% if (it.grove === 'moon') { %>
  <svg class="composer-fungi composer-scene-moon" viewBox="0 0 400 112" aria-hidden="true">
    <circle class="composer-moon-disc" cx="304" cy="53" r="47"/>
    <g class="composer-spores">
      <circle cx="94" cy="42" r="2.5"/><circle cx="139" cy="19" r="2"/><circle cx="205" cy="34" r="3"/>
      <circle cx="251" cy="13" r="1.8"/><circle cx="361" cy="23" r="2.4"/>
    </g>
    <path class="composer-moss composer-moss-back" d="M8 112C32 78 63 80 88 112c26-48 72-47 102 0 27-37 65-38 91 0 28-52 80-53 111 0Z"/>
