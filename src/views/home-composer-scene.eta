    <path class="composer-moss composer-moss-front" d="M4 112c31-23 65-23 98 0 33-27 73-27 106 0 34-24 72-25 106 0 28-21 55-21 82 0Z"/>
  </svg>
<% } else { %>
  <svg class="composer-fungi composer-scene-ridge" viewBox="0 0 400 112" aria-hidden="true">
    <g class="composer-spores">
      <circle cx="79" cy="48" r="3"/><circle cx="113" cy="21" r="2"/><circle cx="181" cy="37" r="2.5"/>
      <circle cx="261" cy="18" r="3"/><circle cx="332" cy="31" r="1.8"/><circle cx="370" cy="11" r="2.4"/>
    </g>
    <path class="composer-moss composer-moss-back" d="M8 112c24-38 60-40 87 0 28-53 76-54 108 0 27-42 68-43 97 0 28-47 71-48 92 0Z"/>
    <path class="composer-stem" d="M83 112c5-13 5-25 2-36h13c-3 13-2 25 3 36Zm70 0c5-23 6-43 1-61h17c-4 20-3 40 4 61Zm91 0c4-17 4-31 1-44h14c-3 15-2 29 4 44Zm76 0c7-29 8-55 2-78h20c-5 26-3 52 5 78Z"/>
