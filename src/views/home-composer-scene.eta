  </svg>
<% } else if (it.grove === 'lichen') { %>
  <svg class="composer-fungi composer-scene-log" viewBox="0 0 400 112" aria-hidden="true">
    <g class="composer-spores">
      <circle cx="75" cy="30" r="2"/><circle cx="118" cy="17" r="2.8"/><circle cx="286" cy="24" r="2.2"/>
      <circle cx="331" cy="11" r="1.7"/><circle cx="369" cy="37" r="2.5"/>
    </g>
    <path class="composer-moss composer-moss-back" d="M8 112c25-35 58-35 84 0 28-42 69-43 97 0 27-34 62-35 89 0 29-44 75-43 114 0Z"/>
    <path class="composer-log" d="M52 83c72-13 186-9 283 2 22 3 34 13 42 27H31c3-15 9-25 21-29Z"/>
