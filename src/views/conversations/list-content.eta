<%~ include('./sidebar', it) %>

<section class="scroll-thin flex min-h-0 min-w-0 flex-1 flex-col overflow-y-auto">
  <div class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-stretch justify-start gap-6 px-4 py-6 lg:items-center lg:justify-center lg:gap-8 lg:py-10">
    <div class="grid w-full gap-1 lg:hidden">
      <h1 class="text-[clamp(2rem,5vw,2.75rem)] font-extrabold tracking-tight">Chats</h1>
    </div>

    <div class="hidden justify-items-center gap-2 text-center lg:grid">
      <h1 class="text-[clamp(2rem,5vw,2.75rem)] font-extrabold tracking-tight">Hello there</h1>
      <% if (it.providers.length === 0) { %>
        <p class="text-ink-dim">Connect a provider and this becomes a chat.</p>
      <% } else { %>
        <p class="text-ink-dim">Type a message to start a new conversation.</p>
      <% } %>
    </div>

    <% if (it.providers.length === 0) { %>
      <% /* Onboarding: no enabled providers yet — walk through the one setup
            step instead of showing a composer that can't send. */ %>
      <div class="card grid w-full gap-4">
        <div class="grid gap-1">
          <h2 class="text-lg font-bold">Connect a provider first</h2>
          <p class="mb-0 text-sm text-ink-dim">
            inkcap talks to your own endpoints — a local llama-server or any
            OpenAI-compatible API. Keys stay on the server, never in the browser.
          </p>
        </div>
        <ol class="grid list-decimal gap-1.5 pl-5 text-sm text-ink-dim">
          <li>Start your server, e.g. <code class="rounded bg-ink/5 px-1 py-0.5 font-mono text-xs">llama-server -m model.gguf --port 8001</code></li>
          <li>Register its URL as a provider</li>
          <li>Come back here and say hello</li>
        </ol>
        <a class="btn btn-primary justify-self-start" href="/providers/new">Add your first provider</a>
      </div>
    <% } else { %>
      <form id="new-chat" class="grid w-full scroll-mt-4 gap-2 rounded-[1.75rem] border border-edge bg-veil p-3 shadow-xl shadow-black/5 backdrop-blur-xl" method="post" action="/conversations" data-new-chat>
        <% if (it.errors.length > 0) { %>
          <div class="alert-danger" role="alert">
            <% it.errors.forEach((error) => { %>
              <p class="mb-0 last:mb-0"><%= error %></p>
            <% }) %>
          </div>
        <% } %>

        <textarea class="max-h-64 w-full resize-none border-0 bg-transparent px-2 py-1.5 text-ink outline-none placeholder:text-ink-faint" name="content" rows="2" placeholder="Type a message…" data-chat-input><%= it.values.content || '' %></textarea>

        <div class="grid grid-cols-[auto_minmax(0,1fr)] items-center gap-2 sm:flex sm:flex-nowrap">
          <details class="relative" data-close-on-outside>
            <summary class="chip cursor-pointer transition-colors select-none hover:border-edge-strong hover:text-ink">
              <%~ include('../partials/icon', { name: 'sliders', class: 'size-3.5' }) %>
              Tools
            </summary>
            <div class="absolute bottom-full left-0 z-10 mb-2 grid w-[min(26rem,calc(100vw-3rem))] gap-3 rounded-2xl border border-edge bg-raised p-4 shadow-xl shadow-black/10" data-menu-panel>
              <%~ include('./mcp-picker', { servers: it.mcpServers }) %>
            </div>
          </details>

          <div class="flex min-w-0 items-center justify-end gap-2 sm:ml-auto">
            <%~ include('./model-controls', { controls: it.modelControls }) %>
            <button class="grid size-9 shrink-0 cursor-pointer place-items-center rounded-full border-0 bg-accent text-on-accent transition-colors hover:bg-accent-hover" type="submit" aria-label="Send">
              <%~ include('../partials/icon', { name: 'send', class: 'size-4' }) %>
            </button>
          </div>
        </div>
      </form>
    <% } %>

    <section class="grid w-full gap-2 rounded-2xl border border-edge bg-raised p-2 shadow-sm shadow-black/5 lg:hidden" aria-labelledby="mobile-recent-chats">
      <div class="flex items-baseline justify-between gap-3 px-2 pt-1">
        <h2 id="mobile-recent-chats" class="text-xs font-semibold tracking-wider text-ink-faint uppercase">Recent chats</h2>
        <% if (it.sidebar.length > 0) { %>
          <span class="text-xs text-ink-faint"><%= it.sidebar.length %></span>
        <% } %>
      </div>
      <% if (it.sidebar.length > 0) { %>
        <nav class="grid gap-1" aria-label="Recent chats">
          <% it.sidebar.forEach((row) => { %>
            <a class="flex min-w-0 items-baseline justify-between gap-3 rounded-xl px-3 py-2.5 text-sm no-underline text-ink-dim transition-colors hover:bg-ink/5 hover:text-ink" href="/conversations/<%= row.id %>">
              <span class="min-w-0 truncate"><%= row.title || 'New chat' %></span>
              <span class="shrink-0 text-xs text-ink-faint"><%= row.updatedLabel %></span>
            </a>
          <% }) %>
        </nav>
      <% } else { %>
        <div class="rounded-xl border border-dashed border-edge p-4 text-sm text-ink-faint">No chats yet.</div>
      <% } %>
    </section>
  </div>
</section>

<script src="/assets/<%= it.assetVersion %>/chat.js" defer></script>
