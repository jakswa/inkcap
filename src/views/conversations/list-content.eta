<%~ include('./sidebar', it) %>

<section class="scroll-thin flex min-h-0 min-w-0 flex-1 flex-col overflow-y-auto">
  <div class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-stretch justify-start gap-6 px-4 py-6 lg:items-center lg:justify-center lg:gap-8 lg:py-10">
    <div class="grid w-full gap-1 lg:hidden">
      <h1 class="text-[clamp(2rem,5vw,2.75rem)] font-extrabold tracking-tight">Chats</h1>
    </div>

    <div class="hidden justify-items-center gap-2 text-center lg:grid">
      <h1 class="text-[clamp(2rem,5vw,2.75rem)] font-extrabold tracking-tight">Hello there</h1>
      <% if (it.providers.length === 0) { %>
        <p class="text-ink-dim">Connect a provider and this becomes a chat.</p>
      <% } else { %>
        <p class="text-ink-dim">Type a message to start a new conversation.</p>
      <% } %>
    </div>

    <%~ include('./new-chat-composer', it) %>

    <section class="grid w-full gap-2 rounded-2xl border border-edge bg-raised p-2 shadow-sm shadow-black/5 lg:hidden" aria-labelledby="mobile-recent-chats">
      <div class="flex items-baseline justify-between gap-3 px-2 pt-1">
        <h2 id="mobile-recent-chats" class="text-xs font-semibold tracking-wider text-ink-faint uppercase">Recent chats</h2>
        <% if (it.sidebar.length > 0) { %>
          <span class="text-xs text-ink-faint"><%= it.sidebar.length %></span>
        <% } %>
      </div>
      <% if (it.sidebar.length > 0) { %>
        <nav class="grid gap-1" aria-label="Recent chats">
          <% it.sidebar.forEach((row) => { %>
            <a class="flex min-w-0 items-baseline justify-between gap-3 rounded-xl px-3 py-2.5 text-sm no-underline text-ink-dim transition-colors hover:bg-ink/5 hover:text-ink" href="/conversations/<%= row.id %>">
              <span class="min-w-0 truncate"><%= row.title || 'New chat' %></span>
              <span class="shrink-0 text-xs text-ink-faint"><%= row.updatedLabel %></span>
            </a>
          <% }) %>
        </nav>
      <% } else { %>
        <div class="rounded-xl border border-dashed border-edge p-4 text-sm text-ink-faint">No chats yet.</div>
      <% } %>
    </section>
  </div>
</section>

<script src="/assets/<%= it.assetVersion %>/chat.js" defer></script>
