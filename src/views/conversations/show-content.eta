<%~ include('./sidebar', it) %>

<div id="chat" class="flex min-w-0 flex-1 flex-col" data-chat data-conversation="<%= it.conversation.id %>" data-events="/conversations/<%= it.conversation.id %>/events?after=<%= it.eventCursor || 0 %>"<% if (it.activeRun) { %> data-active="1"<% } %>>
  <header class="flex h-12 shrink-0 items-center gap-1 border-b border-edge bg-veil px-3 backdrop-blur-xl">
    <a class="icon-btn lg:hidden" href="/conversations" aria-label="All chats" title="All chats">
      <%~ include('../partials/icon', { name: 'arrowLeft', class: 'size-4' }) %>
    </a>
    <p class="m-0 min-w-0 flex-1 truncate px-1 text-sm font-semibold text-ink"><%= it.conversation.title || 'New chat' %></p>
    <% if (!it.provider) { %>
      <span class="chip border-warn/40 text-warn">no provider</span>
    <% } else if (!it.provider.enabled) { %>
      <span class="chip border-warn/40 text-warn"><%= it.provider.name %> disabled</span>
    <% } %>
    <form method="post" action="/conversations/<%= it.conversation.id %>/fork">
      <button class="icon-btn" type="submit" aria-label="Fork conversation" title="Fork conversation — copy this path into a new chat">
        <%~ include('../partials/icon', { name: 'fork', class: 'size-4' }) %>
      </button>
    </form>
  </header>

  <div class="scroll-thin min-h-0 flex-1 overflow-y-auto" data-scroller>
    <div class="mx-auto grid min-w-0 w-full max-w-3xl gap-6 px-4 py-6" data-transcript>
      <% if (it.messages.length === 0) { %>
        <div class="grid gap-1 py-16 text-center" data-empty>
          <p class="mb-0 text-lg font-semibold text-ink">Hello there</p>
          <p class="mb-0 text-sm text-ink-dim">Send a message to get started.</p>
        </div>
      <% } else { %>
        <% if (it.artifacts && it.artifacts.length > 0) { %>
          <section class="grid gap-2 rounded-2xl border border-accent/25 bg-accent/5 p-4">
            <h2 class="text-sm font-bold tracking-wider text-accent uppercase">Artifacts</h2>
            <div class="grid gap-2">
              <% it.artifacts.forEach((artifact) => { %>
                <a class="flex min-w-0 max-w-full items-baseline justify-between gap-3 overflow-hidden rounded-xl bg-raised px-3 py-2 no-underline transition-colors hover:bg-ink/5" href="/artifacts/<%= artifact.id %>">
                  <span class="min-w-0 flex-1 truncate font-semibold"><%= artifact.title %></span>
                  <span class="shrink-0 truncate text-xs text-ink-faint"><%= artifact.kind %></span>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>
        <% for (const message of it.messages) { %>
          <%~ await includeAsync('./message', { message: message }) %>
        <% } %>
      <% } %>
    </div>

    <% /* No-JS fallback: while a run streams, meta-refresh re-renders the page
          so plain HTML still shows the reply landing. The island cancels this
          by taking over the SSE live tail when JS is on. */ %>
    <% if (it.activeRun) { %>
      <noscript><meta http-equiv="refresh" content="3"></noscript>
    <% } %>

    <% if (it.pendingApproval) { %>
      <div class="mx-auto w-full max-w-3xl px-4 pb-6">
        <%~ await includeAsync('./pending-approval', it) %>
      </div>
    <% } %>
  </div>

  <div class="shrink-0 px-4 pt-1 pb-4">
    <div class="mx-auto grid w-full max-w-3xl gap-2" data-controls>
      <div class="flex min-w-0 items-center gap-2 px-2 text-xs text-ink-dim <%= it.activeRun ? '' : 'hidden' %>" data-status role="status" aria-live="polite">
        <% if (it.activeRun) { %>
          <span class="relative flex size-2 shrink-0" aria-hidden="true"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-60"></span><span class="relative inline-flex size-2 rounded-full bg-accent"></span></span>
        <% } %>
        <span class="min-w-0 flex-1 truncate whitespace-nowrap" data-status-text title="<%= it.activeRun ? 'Generating…' : '' %>"><%= it.activeRun ? 'Generating…' : '' %></span>
      </div>

      <div class="alert-danger <%= it.error ? '' : 'hidden' %>" role="alert" data-composer-error>
        <span data-composer-error-text><%= it.error || '' %></span>
      </div>
      <% if (it.runError) { %>
        <div class="alert-danger" role="alert" data-run-error>
          <p class="mb-1 font-bold">The model could not complete this reply</p>
          <p class="mb-0 break-words"><%= it.runError %></p>
          <p class="mb-0 mt-2 text-sm">Review the error, adjust the model or provider settings if needed, then send again.</p>
        </div>
      <% } %>

      <form id="mcp-tools-form" class="hidden" method="post" action="/conversations/<%= it.conversation.id %>/tools">
        <input type="hidden" name="redirect_to" value="conversation">
      </form>
      <form class="grid gap-2 rounded-[1.75rem] border border-edge bg-veil p-3 shadow-xl shadow-black/10 backdrop-blur-xl" data-composer method="post" action="/conversations/<%= it.conversation.id %>/messages">
        <textarea class="max-h-64 w-full resize-none border-0 bg-transparent px-2 py-1.5 text-ink outline-none placeholder:text-ink-faint" name="content" rows="1" placeholder="Type a message…" data-composer-input data-chat-input><%= it.draft %></textarea>
        <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-2 sm:flex sm:flex-nowrap">
          <details class="relative" data-close-on-outside>
            <summary class="chip cursor-pointer transition-colors select-none hover:border-edge-strong hover:text-ink">
              <%~ include('../partials/icon', { name: 'sliders', class: 'size-3.5' }) %>
              Tools
              <span class="rounded-full bg-accent/15 px-1.5 py-0.5 text-[0.6875rem] font-bold text-accent <%= it.enabledMcpServerCount > 0 ? '' : 'hidden' %>" data-tools-count><%= it.enabledMcpServerCount %></span>
            </summary>
            <div class="absolute bottom-full left-0 z-10 mb-2 grid w-[min(26rem,calc(100vw-3rem))] gap-3 rounded-2xl border border-edge bg-raised p-4 shadow-xl shadow-black/10" data-menu-panel>
              <%~ include('./mcp-picker', { servers: it.mcpServers, formId: 'mcp-tools-form' }) %>
              <div class="flex flex-wrap items-center gap-2 border-t border-edge pt-3">
                <button class="btn btn-primary" type="submit" form="mcp-tools-form">Save tool choices</button>
                <a class="btn btn-ghost" href="/mcp-servers">Manage MCP</a>
              </div>
            </div>
          </details>
          <div class="flex min-w-0 items-center justify-end gap-2 sm:ml-auto">
            <%~ include('./model-controls', { controls: it.modelControls }) %>
          </div>
          <% if (it.activeRun) { %>
            <button class="grid size-9 shrink-0 cursor-pointer place-items-center rounded-full border-0 bg-ink text-page transition-opacity hover:opacity-80" type="submit" form="cancel-run" aria-label="Stop generating" title="Stop generating">
              <%~ include('../partials/icon', { name: 'stop', class: 'size-4' }) %>
            </button>
          <% } else { %>
            <button class="grid size-9 shrink-0 cursor-pointer place-items-center rounded-full border-0 bg-accent text-on-accent transition-colors hover:bg-accent-hover" type="submit" aria-label="Send">
              <%~ include('../partials/icon', { name: 'send', class: 'size-4' }) %>
            </button>
          <% } %>
        </div>
      </form>
      <form id="cancel-run" class="hidden" data-cancel method="post" action="/conversations/<%= it.conversation.id %>/cancel"></form>
    </div>
  </div>
</div>

<script src="/assets/<%= it.assetVersion %>/chat.js" defer></script>
