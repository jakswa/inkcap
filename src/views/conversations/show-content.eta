<section class="grid items-start gap-6 lg:grid-cols-[15rem_minmax(0,1fr)]">
  <aside class="hidden lg:block lg:sticky lg:top-6">
    <div class="mb-3 flex items-center justify-between">
      <p class="text-xs font-extrabold uppercase tracking-[0.14em] text-indigo-600">Chats</p>
      <a class="text-sm font-bold text-indigo-600 underline-offset-4 hover:underline" href="/conversations">+ New</a>
    </div>
    <nav class="grid gap-1" aria-label="Conversations">
      <% it.sidebar.forEach((row) => { %>
        <a class="grid gap-0.5 rounded-lg px-3 py-2 no-underline <%= row.current ? 'bg-indigo-50 text-indigo-900' : 'text-slate-700 hover:bg-slate-100' %>" href="/conversations/<%= row.id %>"<% if (row.current) { %> aria-current="page"<% } %>>
          <span class="truncate text-sm font-semibold"><%= row.title || 'untitled' %></span>
          <span class="text-xs text-slate-400"><%= row.updatedLabel %></span>
        </a>
      <% }) %>
    </nav>
  </aside>

  <div id="chat" class="flex min-h-[70vh] flex-col gap-4" data-chat data-conversation="<%= it.conversation.id %>" data-events="/conversations/<%= it.conversation.id %>/events"<% if (it.activeRun) { %> data-active="1"<% } %>>
    <header class="grid gap-1">
      <a class="text-sm text-indigo-600 underline-offset-4 hover:underline lg:hidden" href="/conversations">← All conversations</a>
      <h1 class="text-[clamp(1.5rem,4vw,2.25rem)] font-extrabold leading-tight tracking-[-0.03em]"><%= it.conversation.title || 'untitled' %></h1>
      <p class="text-sm text-slate-500">
        <% if (it.provider) { %>
          <%= it.provider.name %><% if (!it.provider.enabled) { %> <span class="text-amber-600">(disabled)</span><% } %>
        <% } else { %>
          <span class="text-amber-600">no provider assigned</span>
        <% } %>
        <% if (it.conversation.model) { %> · <%= it.conversation.model %><% } %>
      </p>
    </header>

    <div class="mx-auto flex w-full max-w-2xl flex-1 flex-col gap-3" data-transcript>
      <% if (it.messages.length === 0) { %>
        <p class="text-slate-500" data-empty>No messages yet. Say something below.</p>
      <% } else { %>
        <% for (const message of it.messages) { %>
          <%~ await includeAsync('./message', { message: message }) %>
        <% } %>
      <% } %>
    </div>

    <% /* No-JS fallback: while a run streams, meta-refresh re-renders the page
          so plain HTML still shows the reply landing. The island cancels this
          by taking over the SSE live tail when JS is on. */ %>
    <% if (it.activeRun) { %>
      <noscript><meta http-equiv="refresh" content="3"></noscript>
    <% } %>

    <div class="mx-auto w-full max-w-2xl" data-controls>
      <div class="flex items-center gap-3 text-sm text-slate-500 <%= it.activeRun ? '' : 'hidden' %>" data-status role="status" aria-live="polite">
        <% if (it.activeRun) { %><span data-status-text>Generating…</span><% } else { %><span data-status-text></span><% } %>
        <form class="contents <%= it.activeRun ? '' : 'hidden' %>" data-cancel method="post" action="/conversations/<%= it.conversation.id %>/cancel">
          <button class="cursor-pointer rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-bold text-slate-700 hover:border-red-400 hover:text-red-700" type="submit">Stop generating</button>
        </form>
      </div>
    </div>

    <form class="sticky bottom-0 mx-auto grid w-full max-w-2xl gap-2 rounded-2xl border border-slate-200 bg-white/90 p-3 shadow-lg shadow-slate-900/5 backdrop-blur" data-composer method="post" action="/conversations/<%= it.conversation.id %>/messages">
      <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800 <%= it.error ? '' : 'hidden' %>" role="alert" data-composer-error>
        <span data-composer-error-text><%= it.error || '' %></span>
      </div>
      <textarea class="w-full resize-y rounded-lg border border-slate-300 px-3 py-2.5" name="content" rows="3" placeholder="Type your message…" data-composer-input><%= it.draft %></textarea>
      <div class="flex justify-end">
        <button class="inline-flex cursor-pointer items-center justify-center rounded-lg border-0 bg-indigo-600 px-4 py-2.5 font-bold text-white hover:bg-indigo-700" type="submit">Send</button>
      </div>
    </form>
  </div>
</section>

<script src="/assets/<%= it.assetVersion %>/chat.js" defer></script>
