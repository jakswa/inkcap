<section class="grid gap-6">
  <div class="grid gap-2">
    <a class="text-sm text-indigo-600 underline-offset-4 hover:underline" href="/conversations">← All conversations</a>
    <h1 class="text-[clamp(1.75rem,5vw,3rem)] font-extrabold leading-tight tracking-[-0.04em]"><%= it.conversation.title || 'untitled' %></h1>
    <p class="text-sm text-slate-500">
      <% if (it.provider) { %>
        <%= it.provider.name %><% if (!it.provider.enabled) { %> <span class="text-amber-600">(disabled)</span><% } %>
      <% } else { %>
        <span class="text-amber-600">no provider assigned</span>
      <% } %>
      <% if (it.conversation.model) { %> · <%= it.conversation.model %><% } %>
    </p>
  </div>

  <div class="grid gap-3" data-chat data-events="/conversations/<%= it.conversation.id %>/events" <% if (it.activeRun) { %>data-active="1"<% } %>>
    <% if (it.messages.length === 0) { %>
      <p class="text-slate-500">No messages yet. Say something below.</p>
    <% } else { %>
      <% for (const message of it.messages) { %>
        <%~ await includeAsync('./message', { message: message }) %>
      <% } %>
    <% } %>
  </div>

  <% if (it.activeRun) { %>
    <% /* No-JS fallback: re-render the page every 3s while the run streams;
          the script below upgrades to the SSE live tail when JS is on. */ %>
    <noscript><meta http-equiv="refresh" content="3"></noscript>
    <form class="grid justify-items-start gap-2" method="post" action="/conversations/<%= it.conversation.id %>/cancel">
      <button class="inline-flex cursor-pointer items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 font-bold text-slate-700 hover:border-red-400 hover:text-red-700" type="submit">Stop generating</button>
    </form>
    <script src="/assets/<%= it.assetVersion %>/chat.js" defer></script>
  <% } %>

  <form class="grid gap-3 rounded-lg border border-slate-300 bg-white p-4 shadow-sm shadow-slate-900/10" method="post" action="/conversations/<%= it.conversation.id %>/messages">
    <% if (it.error) { %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-red-800" role="alert">
        <p class="mb-0"><%= it.error %></p>
      </div>
    <% } %>

    <label class="grid gap-1.5">
      <span class="text-sm font-bold">Message</span>
      <textarea class="w-full rounded-lg border border-slate-300 px-3 py-2.5" name="content" rows="4" placeholder="Type your message…"><%= it.draft %></textarea>
    </label>

    <button class="inline-flex cursor-pointer items-center justify-center justify-self-start rounded-lg border-0 bg-indigo-600 px-4 py-2.5 font-bold text-white hover:bg-indigo-700" type="submit">Send</button>
  </form>
</section>
