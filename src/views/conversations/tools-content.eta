<section class="grid gap-6">
  <div class="grid gap-2">
    <a class="link inline-flex items-center gap-1.5 text-sm" href="/conversations/<%= it.conversation.id %>">
      <%~ include('../partials/icon', { name: 'arrowLeft', class: 'size-4' }) %>
      Back to conversation
    </a>
    <h1 class="text-[clamp(1.75rem,5vw,2.75rem)] font-extrabold leading-tight tracking-tight">Tools for this conversation</h1>
    <p class="mb-0 text-sm text-ink-dim">Turn on an MCP server to expose its tools to the model in this conversation. Off by default.</p>
  </div>

  <form class="card grid gap-4" method="post" action="/conversations/<%= it.conversation.id %>/tools">
    <%~ include('./mcp-picker', { servers: it.servers }) %>
    <button class="btn btn-primary justify-self-start" type="submit">Save tool choices</button>
  </form>
</section>
