<% const servers = it.servers || [] %>
<% const formId = it.formId || '' %>

<section class="grid gap-3">
  <div class="grid gap-1">
    <h2 class="m-0 text-sm font-bold text-ink">MCP tools</h2>
    <p class="mb-0 text-xs text-ink-dim">Choose which registered servers this chat may use. Servers are off per chat until selected.</p>
  </div>

  <% if (servers.length === 0) { %>
    <div class="rounded-xl border border-dashed border-edge p-3 text-sm text-ink-dim">
      No MCP servers registered. <a class="link" href="/mcp-servers/new">Add one</a> first.
    </div>
  <% } else { %>
    <div class="grid gap-2">
      <% servers.forEach((server) => { %>
        <label class="group flex cursor-pointer items-start gap-3 rounded-xl border border-edge bg-page/60 p-3 transition-colors hover:border-edge-strong">
          <input type="hidden" name="mcp_server_id" value="<%= server.id %>"<% if (formId) { %> form="<%= formId %>"<% } %>>
          <input class="mt-0.5 size-4 shrink-0 accent-accent" type="checkbox" name="enabled_mcp_server_id" value="<%= server.id %>" aria-label="<%= server.override_enabled ? 'On — turn off' : 'Off — turn on' %> <%= server.name %>" <%= server.override_enabled ? 'checked' : '' %><% if (formId) { %> form="<%= formId %>"<% } %>>
          <span class="min-w-0">
            <span class="flex min-w-0 flex-wrap items-center gap-1.5">
              <span class="truncate text-sm font-semibold text-ink"><%= server.name %></span>
              <% if (!server.enabled) { %>
                <span class="chip text-[0.6875rem]">Globally disabled</span>
              <% } %>
              <% if (server.auto_approve) { %>
                <span class="chip border-warn/40 text-[0.6875rem] text-warn">Auto-approve</span>
              <% } %>
            </span>
            <span class="mt-0.5 block truncate text-xs text-ink-dim"><%= server.url %></span>
          </span>
        </label>
      <% }) %>
    </div>
  <% } %>
</section>
