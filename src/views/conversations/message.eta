<% const m = it.message %>
<% const artifactLinks = m.artifactLinks || [] %>
<% const toolCall = m.toolCall || null %>
<% /* One partial for every role, shared by the SSR transcript and the
      runner's finalize-swap (action URLs use m.conversation_id, present on
      the row). Streaming keeps plain-text <pre> nodes the island appends
      into; message-final swaps in this same partial's settled render. */ %>
<% if (m.role === 'system' || m.role === 'tool') { %>
  <article class="group grid min-w-0 max-w-full gap-2" data-message-id="<%= m.id %>" data-role="<%= m.role %>" data-status="<%= m.status %>"<% if (m.tool_call_id) { %> data-tool-call-id="<%= m.tool_call_id %>"<% } %>>
    <% if (artifactLinks.length > 0) { %>
      <% artifactLinks.forEach((artifact) => { %>
        <div class="min-w-0 overflow-hidden rounded-2xl border border-accent/30 bg-accent/10 p-3 shadow-sm shadow-black/5">
          <div class="flex min-w-0 flex-wrap items-center justify-between gap-3">
            <div class="flex min-w-0 flex-1 items-center gap-3">
              <span class="grid size-9 shrink-0 place-items-center rounded-xl bg-accent/15 text-accent">
                <%~ include('../partials/icon', { name: 'sparkles', class: 'size-4' }) %>
              </span>
              <div class="min-w-0 flex-1">
                <p class="mb-0 text-xs font-bold tracking-wider text-accent uppercase">Artifact created</p>
                <a class="block max-w-full truncate text-sm font-bold text-ink no-underline hover:underline" href="<%= artifact.href %>"><%= artifact.title %></a>
              </div>
            </div>
            <div class="flex w-full shrink-0 gap-2 sm:w-auto">
              <a class="btn btn-primary flex-1 px-3 py-1.5 text-xs sm:flex-none" href="<%= artifact.href %>">Open</a>
              <a class="btn btn-ghost flex-1 px-3 py-1.5 text-xs sm:flex-none" href="<%= artifact.downloadHref %>" download>Download</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
    <details class="group/acc min-w-0 max-w-full overflow-hidden rounded-2xl border border-edge bg-raised/60 px-4 py-2.5 text-sm <%= artifactLinks.length > 0 ? 'opacity-80' : '' %>">
      <summary class="flex min-w-0 cursor-pointer items-center gap-2 font-semibold text-ink-dim select-none">
        <%~ include('../partials/icon', { name: m.role === 'tool' ? (toolCall ? toolCall.icon : 'terminal') : 'sliders', class: 'size-4' }) %>
        <% if (m.role === 'tool') { %>
          <span class="min-w-0 break-words [overflow-wrap:anywhere]">Tool result: <%= toolCall ? toolCall.name : (artifactLinks.length > 0 ? 'submit_artifact' : 'unknown tool') %></span>
        <% } else { %>
          <span class="min-w-0">System prompt</span>
        <% } %>
        <%~ include('../partials/icon', { name: 'chevronDown', class: 'ml-auto size-4 transition-transform group-open/acc:rotate-180' }) %>
      </summary>
      <% if (m.role === 'tool' && toolCall && toolCall.arguments && toolCall.arguments !== '{}') { %>
        <div class="mt-3 rounded-xl border border-edge bg-page/45 p-3">
          <p class="mb-1 text-xs font-bold tracking-wider text-ink-faint uppercase">Arguments</p>
          <pre class="m-0 max-w-full overflow-x-hidden whitespace-pre-wrap break-words font-mono text-xs text-ink-dim [overflow-wrap:anywhere]"><%= toolCall.arguments %></pre>
        </div>
      <% } %>
      <pre class="m-0 mt-2 max-w-full overflow-x-hidden whitespace-pre-wrap break-words text-ink-dim [overflow-wrap:anywhere] <%= m.role === 'tool' ? 'font-mono text-xs' : 'font-body' %>" data-content><%= m.content %></pre>
    </details>
  </article>
<% } else if (m.role === 'user') { %>
  <article class="group grid justify-items-end gap-1.5" data-message-id="<%= m.id %>" data-role="user" data-status="<%= m.status %>">
    <div class="max-w-[85%] rounded-3xl rounded-br-lg bg-ink/8 px-4 py-2.5">
      <% if (m.status === 'streaming') { %>
        <pre class="m-0 font-body whitespace-pre-wrap break-words text-ink" data-content><%= m.content %></pre>
      <% } else { %>
        <div class="md [&:empty]:hidden" data-content><%~ m.contentHtml %></div>
      <% } %>
    </div>

    <% if (m.status !== 'streaming' && m.id) { %>
      <div class="msg-actions flex items-center gap-0.5 text-ink-faint">
        <%~ include('./message-siblings', { m: m }) %>
        <button class="js-only icon-btn size-7" type="button" data-copy data-clip="<%= m.clipContent %>" aria-label="Copy message" title="Copy">
          <%~ include('../partials/icon', { name: 'copy', class: 'size-4' }) %>
        </button>
        <details class="relative" data-edit>
          <summary class="icon-btn size-7" aria-label="Edit message" title="Edit — saves as a new branch and regenerates">
            <%~ include('../partials/icon', { name: 'pencil', class: 'size-4' }) %>
          </summary>
          <div class="absolute bottom-full right-0 z-10 mb-1 w-[min(32rem,calc(100vw-3rem))] rounded-2xl border border-edge bg-raised p-3 shadow-xl shadow-black/10">
            <form class="grid gap-2" method="post" action="/conversations/<%= m.conversation_id %>/messages/<%= m.id %>/edit">
              <textarea class="input text-sm" name="content" rows="4"><%= m.content %></textarea>
              <div class="flex justify-end">
                <button class="btn btn-primary px-3 py-1.5 text-xs" type="submit">Save &amp; regenerate</button>
              </div>
            </form>
          </div>
        </details>
        <%~ include('./message-delete', { m: m, align: 'right' }) %>
      </div>
    <% } %>
  </article>
<% } else { %>
  <article class="group grid gap-3.5 py-1 <%= m.hideMessage ? 'hidden' : '' %>" data-message-id="<%= m.id %>" data-role="<%= m.role %>" data-status="<%= m.status %>">
    <% if (m.status === 'streaming') { %>
      <% /* Live path: the island appends plain-text deltas into these nodes,
            then message-final swaps this whole <article> for the settled
            render. */ %>
      <pre class="m-0 hidden rounded-2xl border border-edge bg-raised/60 px-4 py-3 font-body text-sm whitespace-pre-wrap break-words text-ink-dim [&:not(:empty)]:block" data-reasoning><%= m.reasoning_content || '' %></pre>
      <pre class="m-0 hidden rounded-3xl rounded-bl-lg border border-edge bg-raised/35 px-4 py-3.5 font-body whitespace-pre-wrap break-words text-ink shadow-sm shadow-black/5 [&:not(:empty)]:block" data-content><%= m.content %></pre>
    <% } else { %>
      <% if (m.showReasoning) { %>
        <details class="group/acc rounded-2xl border border-edge bg-raised/60 px-4 py-2.5 text-sm">
          <summary class="flex cursor-pointer items-center gap-2 font-semibold text-ink-dim select-none">
            <%~ include('../partials/icon', { name: 'bulb', class: 'size-4' }) %>
            Reasoning
            <%~ include('../partials/icon', { name: 'chevronDown', class: 'ml-auto size-4 transition-transform group-open/acc:rotate-180' }) %>
          </summary>
          <pre class="m-0 mt-2 font-body whitespace-pre-wrap break-words text-ink-dim" data-reasoning><%= m.reasoning_content %></pre>
        </details>
      <% } %>
      <% if (m.showContent) { %>
        <div class="rounded-3xl rounded-bl-lg border border-edge bg-raised/35 px-4 py-3.5 shadow-sm shadow-black/5 md" data-content><%~ m.contentHtml %></div>
      <% } %>
    <% } %>

    <% if (m.status === 'interrupted') { %>
      <p class="mb-0 text-xs font-medium text-warn">interrupted</p>
    <% } %>

    <% if (m.showFooter) { %>
      <footer class="flex max-w-full flex-wrap items-center gap-x-2 gap-y-1 px-1 text-[0.6875rem] leading-snug text-ink-dim sm:text-xs" title="<%= m.timingLabel || '' %>">
        <% if (m.model) { %>
          <span class="inline-flex min-w-0 max-w-full items-center gap-1 rounded-md border border-edge px-1.5 py-1 font-medium sm:max-w-xs" title="<%= m.model %>">
            <%~ include('../partials/icon', { name: 'cube', class: 'size-3 shrink-0' }) %>
            <span class="truncate"><%= m.model %></span>
          </span>
        <% } %>
        <% if (m.stats && m.stats.prompt) { %>
          <span class="inline-flex max-w-full flex-wrap items-center gap-x-1 rounded-md border border-edge px-1.5 py-1">
            <span class="font-semibold text-ink-dim">prompt</span>
            <span><%= m.stats.prompt.tokens %></span>
            <% if (m.stats.prompt.seconds) { %><span>· <%= m.stats.prompt.seconds %></span><% } %>
            <% if (m.stats.prompt.rate) { %><span>· <%= m.stats.prompt.rate %></span><% } %>
          </span>
        <% } %>
        <% if (m.stats && m.stats.generation) { %>
          <span class="inline-flex max-w-full flex-wrap items-center gap-x-1 rounded-md border border-edge px-1.5 py-1">
            <span class="font-semibold text-ink-dim">gen</span>
            <span><%= m.stats.generation.tokens %></span>
            <% if (m.stats.generation.seconds) { %><span>· <%= m.stats.generation.seconds %></span><% } %>
            <% if (m.stats.generation.rate) { %><span>· <%= m.stats.generation.rate %></span><% } %>
          </span>
        <% } %>
        <% if (m.showActions) { %>
          <span class="msg-actions flex items-center gap-0.5 text-ink-faint sm:ml-auto">
            <%~ include('./message-siblings', { m: m }) %>
            <button class="js-only icon-btn size-7" type="button" data-copy data-clip="<%= m.clipContent %>" aria-label="Copy message" title="Copy">
              <%~ include('../partials/icon', { name: 'copy', class: 'size-4' }) %>
            </button>
            <form class="contents" method="post" action="/conversations/<%= m.conversation_id %>/messages/<%= m.id %>/regenerate">
              <button class="icon-btn size-7" type="submit" aria-label="Regenerate" title="Regenerate — the old reply stays as a branch">
                <%~ include('../partials/icon', { name: 'refresh', class: 'size-4' }) %>
              </button>
            </form>
            <%~ include('./message-delete', { m: m, align: 'left' }) %>
          </span>
        <% } %>
      </footer>
    <% } %>
  </article>
<% } %>
