<article class="grid gap-1 rounded-lg border border-slate-300 bg-white p-4 shadow-sm shadow-slate-900/10" data-message-id="<%= it.message.id %>" data-status="<%= it.message.status %>">
  <p class="text-xs font-extrabold uppercase tracking-[0.14em] text-indigo-600">
    <%= it.message.role %>
    <% if (it.message.status === 'streaming') { %><span class="text-slate-400">(streaming…)</span><% } %>
    <% if (it.message.status === 'interrupted') { %><span class="text-amber-600">(interrupted)</span><% } %>
  </p>
  <% if (it.message.reasoning_content || it.message.status === 'streaming') { %>
    <pre class="m-0 whitespace-pre-wrap break-words font-body text-sm text-slate-500" data-reasoning><%= it.message.reasoning_content || '' %></pre>
  <% } %>
  <pre class="m-0 whitespace-pre-wrap break-words font-body text-slate-900" data-content><%= it.message.content %></pre>
</article>
