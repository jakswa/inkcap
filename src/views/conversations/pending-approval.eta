<div class="grid gap-3 rounded-lg border border-amber-300 bg-amber-50 p-4 shadow-sm shadow-slate-900/10" data-pending-approval>
  <p class="mb-0 text-xs font-extrabold uppercase tracking-[0.14em] text-amber-700">Waiting for approval</p>
  <p class="mb-0 text-sm text-amber-900">The assistant wants to run the following tool<%= it.pendingApproval.calls.length === 1 ? '' : 's' %>. Approve to run <%= it.pendingApproval.calls.length === 1 ? 'it' : 'them' %>, or deny to tell the model no.</p>

  <% it.pendingApproval.calls.forEach((call) => { %>
    <div class="grid gap-1 rounded-lg border border-amber-200 bg-white p-3">
      <p class="mb-0 font-bold text-slate-900"><%= call.toolName %></p>
      <pre class="m-0 overflow-x-auto whitespace-pre-wrap break-words font-mono text-xs text-slate-600"><%= call.arguments %></pre>
    </div>
  <% }) %>

  <div class="flex flex-wrap gap-2">
    <form method="post" action="/conversations/<%= it.conversation.id %>/approvals">
      <input type="hidden" name="decision" value="approve">
      <button class="inline-flex cursor-pointer items-center justify-center rounded-lg border-0 bg-emerald-600 px-4 py-2.5 font-bold text-white hover:bg-emerald-700" type="submit">Approve &amp; run</button>
    </form>
    <form method="post" action="/conversations/<%= it.conversation.id %>/approvals">
      <input type="hidden" name="decision" value="deny">
      <button class="inline-flex cursor-pointer items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 font-bold text-slate-700 hover:border-red-400 hover:text-red-700" type="submit">Deny</button>
    </form>
  </div>
</div>
