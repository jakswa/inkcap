<div class="grid gap-3 rounded-2xl border border-warn/40 bg-warn/10 p-4" data-pending-approval>
  <p class="mb-0 flex items-center gap-2 text-xs font-extrabold tracking-[0.14em] text-warn uppercase">
    <%~ include('../partials/icon', { name: 'shield', class: 'size-4' }) %>
    Waiting for approval
  </p>
  <p class="mb-0 text-sm text-ink">The assistant wants to run the following tool<%= it.pendingApproval.calls.length === 1 ? '' : 's' %>. Approve to run <%= it.pendingApproval.calls.length === 1 ? 'it' : 'them' %>, or deny to tell the model no.</p>

  <% it.pendingApproval.calls.forEach((call) => { %>
    <div class="grid gap-1 rounded-xl border border-edge bg-raised p-3">
      <p class="mb-0 font-mono text-sm font-bold text-ink"><%= call.toolName %></p>
      <pre class="m-0 overflow-x-auto font-mono text-xs whitespace-pre-wrap break-words text-ink-dim"><%= call.arguments %></pre>
    </div>
  <% }) %>

  <div class="flex flex-wrap gap-2">
    <form method="post" action="/conversations/<%= it.conversation.id %>/approvals">
      <input type="hidden" name="decision" value="approve">
      <button class="btn btn-primary" type="submit">Approve &amp; run</button>
    </form>
    <form method="post" action="/conversations/<%= it.conversation.id %>/approvals">
      <input type="hidden" name="decision" value="deny">
      <button class="btn btn-ghost hover:border-danger/50 hover:text-danger" type="submit">Deny</button>
    </form>
  </div>
</div>
