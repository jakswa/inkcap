<%
  const loop = it.loop || {}
  const values = it.values || {}
  const field = (name, fallback = '') => values[name] !== undefined ? values[name] : (loop[name] ?? fallback)
  const selectedProvider = field('providerId', loop.provider_id || '')
  const selectedModel = field('model', loop.model || '')
  const selectedReasoning = field('reasoningEffort', loop.reasoning_effort || 'medium')
  const scheduleMode = field('scheduleMode', it.scheduleParts.mode)
  const scheduleMinute = field('scheduleMinute', it.scheduleParts.minute)
  const scheduleTime = field('scheduleTime', it.scheduleParts.time)
  const scheduleWeekday = field('scheduleWeekday', it.scheduleParts.weekday)
  const scheduleOnce = field('scheduleOnce', it.scheduleParts.once)
  const scheduleCustom = field('scheduleCustom', it.scheduleParts.custom)
  const timezoneValue = it.timeZone
  const enabledValue = values.enabled !== undefined ? values.enabled === 'on' : Boolean(loop.enabled)
  const reasoningOptions = ['off', 'low', 'medium', 'high', 'max']
%>
<section class="grid gap-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="eyebrow mb-3">Loops</p>
      <h1 class="text-[clamp(2rem,5vw,3.25rem)] font-extrabold leading-[1.05] tracking-tight"><%= it.mode === 'new' ? 'New loop' : 'Edit loop' %></h1>
      <p class="mt-4 max-w-3xl text-ink-dim">Configure the task, model, timing, and exactly which tools it may use. New loops start paused unless you explicitly enable a schedule.</p>
    </div>
    <a class="btn btn-ghost" href="/loops">Back to loops</a>
  </div>

  <% if (it.errors.length > 0) { %>
    <div class="alert-danger" role="alert">
      <% it.errors.forEach((error) => { %><p class="mb-0"><%= error %></p><% }) %>
    </div>
  <% } %>

  <form class="grid gap-5" method="post" action="<%= it.mode === 'new' ? '/loops' : `/loops/${loop.id}` %>">
    <div class="card grid gap-4">
      <div><p class="eyebrow mb-1">Step 1</p><h2 class="text-xl font-bold">Task</h2><p class="mb-0 text-sm text-ink-dim">Describe the result you want to make repeatable.</p></div>
      <div class="grid gap-2">
        <label class="text-sm font-semibold" for="name">Name</label>
        <input id="name" name="name" class="input" required maxlength="120" value="<%= field('name', '') %>" placeholder="Morning briefing">
      </div>

      <div class="grid gap-2">
        <label class="text-sm font-semibold" for="prompt">Prompt</label>
        <textarea id="prompt" name="prompt" class="input min-h-44" required placeholder="Write the thing this loop should do..."><%= field('prompt', '') %></textarea>
        <p class="mb-0 text-xs text-ink-faint">Tip: ask the model to call <code>submit_artifact</code> when it has the finished user-facing result.</p>
        <% if (it.notificationsEnabled) { %><p class="mb-0 text-xs text-ink-faint">After completion, the model applies your app-wide <a class="link" href="/settings#notifications">notification guidance</a> to this chat. You can include specifics such as “notify me if there’s movement” in the prompt.</p><% } %>
      </div>

      <details class="grid gap-2">
        <summary class="cursor-pointer text-sm font-semibold text-ink-dim">Optional system prompt</summary>
        <textarea name="system_prompt" class="input mt-2 min-h-28"><%= field('systemPrompt', loop.system_prompt || '') %></textarea>
      </details>
    </div>

    <div class="card grid gap-4">
      <div><p class="eyebrow mb-1">Step 2</p><h2 class="text-xl font-bold">Model</h2><p class="mb-0 text-sm text-ink-dim">Choose the connection and model that should do the work.</p></div>
      <div class="grid gap-2 sm:max-w-2xl">
        <label class="text-sm font-semibold" for="provider_model">Provider &amp; model</label>
        <select id="provider_model" name="provider_model" class="input" required>
          <option value="">Choose a model…</option>
          <% it.providers.forEach((provider) => { const models = provider.models || []; const choices = models.length > 0 ? models : [''] %>
            <optgroup label="<%= provider.name %><%= provider.enabled ? '' : ' (disabled)' %>">
              <% choices.forEach((model) => { const chosen = provider.id === selectedProvider && (model === selectedModel || (!selectedModel && model === provider.default_model)) %>
                <option value="<%= provider.id %>:<%= encodeURIComponent(model) %>" <%= chosen ? 'selected' : '' %> <%= provider.enabled ? '' : 'disabled' %>><%= model || 'Provider default' %></option>
              <% }) %>
            </optgroup>
          <% }) %>
          <% if (selectedProvider && selectedModel && !it.providers.some((provider) => provider.id === selectedProvider && (provider.models || []).includes(selectedModel))) { %><option value="<%= selectedProvider %>:<%= encodeURIComponent(selectedModel) %>" selected><%= selectedModel %> (not in provider catalog)</option><% } %>
        </select>
        <p class="mb-0 text-xs text-ink-faint">Models come from Providers. Refresh a provider there when its server changes.</p>
      </div>
      <div class="grid gap-2 sm:max-w-xs">
        <label class="text-sm font-semibold" for="reasoning_effort">Reasoning effort</label>
        <select id="reasoning_effort" name="reasoning_effort" class="input">
          <% reasoningOptions.forEach((effort) => { %>
            <option value="<%= effort %>" <%= selectedReasoning === effort ? 'selected' : '' %>><%= effort %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="card grid gap-4">
      <div>
        <p class="eyebrow mb-1">Step 3</p><h2 class="text-xl font-bold">When</h2>
        <p class="mb-0 text-sm text-ink-dim">Times use <strong class="text-ink"><%= timezoneValue %></strong>. All loops follow the timezone in <a class="link" href="/settings#regional">Settings</a>.</p>
      </div>
      <%~ include('./schedule-picker', { scheduleMode, scheduleMinute, scheduleTime, scheduleWeekday, scheduleOnce, scheduleCustom }) %>
      <% if (it.schedulePreview) { %><div class="alert-ok"><p class="mb-0"><strong>Next run:</strong> <%= it.schedulePreview %></p></div><% } else if (scheduleMode !== 'manual') { %><p class="mb-0 text-sm text-ink-dim">Save a valid schedule to calculate its next run.</p><% } %>
      <label class="flex items-start gap-3 rounded-xl border border-edge p-3 text-sm"><input class="mt-1" type="checkbox" name="enabled" <%= enabledValue ? 'checked' : '' %>><span><strong class="block">Enable this schedule</strong><span class="text-ink-dim">Unchecked keeps it paused; Run now still works.</span></span></label>
    </div>

    <div class="card grid gap-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="eyebrow mb-1">Step 4</p><h2 class="text-xl font-bold">Tools &amp; permission</h2>
          <p class="mb-0 text-sm text-ink-dim">Each server and its unattended permission are one choice. Calls are not pre-approved unless you select both options.</p>
        </div>
        <a class="btn btn-ghost" href="/mcp-servers">Manage MCP</a>
      </div>
      <% if (it.servers.length === 0) { %>
        <div class="rounded-xl border border-dashed border-edge p-4 text-sm text-ink-faint">No MCP servers configured.</div>
      <% } else { %>
        <div class="grid gap-2">
          <% it.servers.forEach((server) => { %>
            <label class="grid gap-2 rounded-xl border border-edge p-3 sm:grid-cols-[1fr_auto] sm:items-center">
              <span class="flex min-w-0 items-start gap-3">
                <input class="mt-1" type="checkbox" name="enabled_mcp_server_id" value="<%= server.id %>" <%= server.loop_enabled ? 'checked' : '' %> <%= server.enabled ? '' : 'disabled' %>>
                <span class="min-w-0">
                  <span class="block font-semibold"><%= server.name %><%= server.enabled ? '' : ' (disabled)' %></span>
                  <span class="block truncate text-xs text-ink-faint"><%= server.url %></span>
                </span>
              </span>
              <span class="flex items-center gap-2 text-sm text-ink-dim">
                <input type="checkbox" name="auto_approve_mcp_server_id" value="<%= server.id %>" <%= server.loop_enabled && server.loop_auto_approve ? 'checked' : '' %> <%= server.enabled ? '' : 'disabled' %>>
                <span><strong class="block text-ink">Allow without a later click</strong>Calls from this server may run unattended.</span>
              </span>
            </label>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="flex flex-wrap gap-2">
      <button class="btn btn-primary" type="submit">Save loop</button>
      <a class="btn btn-ghost" href="/loops">Cancel</a>
    </div>
  </form>

  <% if (it.mode === 'edit') { %>
    <details class="danger-zone"><summary class="cursor-pointer font-semibold text-danger">Delete this loop…</summary><p class="my-3 text-sm text-ink-dim">This removes the recipe and schedule. Existing run chats remain.</p><form method="post" action="/loops/<%= loop.id %>/delete"><button class="btn btn-danger" type="submit">Yes, permanently delete this loop</button></form></details>
  <% } %>
</section>
