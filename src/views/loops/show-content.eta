<section class="grid gap-6">
  <% if (it.error) { %>
    <div class="alert-danger" role="alert"><p class="mb-0"><%= it.error %></p></div>
  <% } %>

  <div class="flex flex-wrap items-start justify-between gap-4">
    <div class="max-w-3xl">
      <p class="eyebrow mb-3">Loop</p>
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-[clamp(2rem,5vw,3.25rem)] font-extrabold leading-[1.05] tracking-tight"><%= it.loop.name %></h1>
        <span class="status <%= it.loop.enabled ? 'status-healthy' : 'status-neutral' %>"><span aria-hidden="true"></span><%= it.loop.enabled ? 'Enabled' : 'Paused' %></span>
      </div>
      <p class="mt-4 text-ink-dim"><%= it.loop.provider_name || 'Missing provider' %><% if (it.loop.model) { %> · <%= it.loop.model %><% } %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="btn btn-ghost" href="/loops/<%= it.loop.id %>/edit">Edit loop</a>
      <form method="post" action="/loops/<%= it.loop.id %>/run"><button class="btn btn-primary" type="submit">Run now</button></form>
      <% if (it.loop.schedule) { %><form method="post" action="/loops/<%= it.loop.id %>/toggle"><button class="btn btn-ghost" type="submit"><%= it.loop.enabled ? 'Pause schedule' : 'Enable schedule' %></button></form><% } %>
      <a class="btn btn-ghost" href="/loops">All loops</a>
    </div>
  </div>

  <% if (it.pushSubscriptionCount === 0) { %>
    <div class="card flex flex-wrap items-center justify-between gap-3 border-accent/25 bg-accent/5">
      <div>
        <h2 class="text-base font-bold">This loop can notify you when it lands.</h2>
        <p class="mb-0 text-sm text-ink-dim">Enable notifications once, then close your laptop. The server keeps going.</p>
      </div>
      <a class="btn btn-primary" href="/settings#notifications">Enable notifications</a>
    </div>
  <% } %>

  <div class="grid gap-4 lg:grid-cols-[1fr_24rem]">
    <article class="card grid gap-4">
      <h2 class="text-xl font-bold">Prompt</h2>
      <% if (it.loop.system_prompt) { %>
        <details class="rounded-xl border border-edge p-3">
          <summary class="cursor-pointer text-sm font-semibold text-ink-dim">System prompt</summary>
          <pre class="mt-3 whitespace-pre-wrap text-sm text-ink-dim"><%= it.loop.system_prompt %></pre>
        </details>
      <% } %>
      <pre class="whitespace-pre-wrap rounded-xl border border-edge bg-sunken p-4 text-sm leading-relaxed"><%= it.loop.prompt %></pre>
    </article>

    <aside class="grid content-start gap-4">
      <div class="card grid gap-3">
        <h2 class="text-lg font-bold">Timing</h2>
        <p class="mb-0 text-sm"><span class="font-semibold">Schedule:</span> <%= it.loop.scheduleLabel %></p><% if (it.loop.schedule) { %><p class="mb-0 font-mono text-xs text-ink-faint"><%= it.loop.schedule %></p><% } %>
        <p class="mb-0 text-sm"><span class="font-semibold">Timezone:</span> <%= it.loop.timezone %></p>
        <p class="mb-0 text-sm"><span class="font-semibold">Last fired:</span> <%= it.loop.lastFiredLabel %></p>
        <p class="mb-0 text-sm"><span class="font-semibold">Next fire:</span> <%= it.loop.nextFireLabel || 'not scheduled' %></p>
      </div>

      <div class="card grid gap-3">
        <h2 class="text-lg font-bold">Artifact recipe</h2>
        <p class="mb-0 text-sm text-ink-dim">Loop runs automatically get a private <code>submit_artifact</code> tool. For crisp outputs, end prompts with:</p>
        <pre class="whitespace-pre-wrap rounded-xl border border-edge bg-sunken p-3 text-xs">When you have the final result, call submit_artifact with a concise title, kind, summary, and polished Markdown body.</pre>
      </div>
    </aside>
  </div>

  <section class="card grid gap-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h2 class="text-xl font-bold">Run history</h2>
        <p class="mb-0 text-sm text-ink-dim">Every loop run is a normal chat, so you can inspect tokens, tool calls, approvals, and artifacts.</p>
      </div>
      <% if (it.loop.last_conversation_id) { %>
        <a class="btn btn-ghost" href="/conversations/<%= it.loop.last_conversation_id %>">Open latest chat</a>
      <% } %>
    </div>

    <% if (it.history.length === 0) { %>
      <div class="rounded-xl border border-dashed border-edge p-4 text-sm text-ink-faint">No runs yet. Press “Run now” to kick the tires.</div>
    <% } else { %>
      <div class="grid gap-2">
        <% it.history.forEach((run) => { %>
          <article class="grid gap-3 rounded-2xl border border-edge p-4 sm:grid-cols-[1fr_auto] sm:items-center">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <a class="truncate font-semibold" href="/conversations/<%= run.id %>"><%= run.title || 'Untitled loop run' %></a>
                <% if (run.run_status) { %>
                  <span class="status <%= run.run_status === 'done' ? 'status-healthy' : run.run_status === 'error' ? 'status-failed' : run.run_status === 'waiting_approval' ? 'status-waiting' : 'status-neutral' %>"><span aria-hidden="true"></span><%= run.statusLabel %></span>
                <% } %>
                <% if (run.artifact_count > 0) { %>
                  <span class="chip"><%= run.artifact_count %> artifact<%= run.artifact_count === 1 ? '' : 's' %></span>
                <% } %>
              </div>
              <p class="mb-0 mt-1 text-xs text-ink-faint">Started <%= run.createdLabel %> · Updated <%= run.updatedLabel %></p>
              <% if (run.run_error) { %>
                <p class="mb-0 mt-2 text-sm text-danger"><%= run.run_error %></p>
              <% } %>
            </div>
            <div class="flex flex-wrap gap-2 sm:justify-end">
              <% if (run.latest_artifact_id) { %>
                <a class="btn btn-primary" href="/artifacts/<%= run.latest_artifact_id %>">Open artifact</a>
              <% } %>
              <a class="btn btn-ghost" href="/conversations/<%= run.id %>">Open chat</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>
