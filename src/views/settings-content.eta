<section class="grid gap-8">
  <div class="max-w-3xl">
    <p class="eyebrow mb-3">Settings</p>
    <h1 class="text-[clamp(2rem,5vw,3.25rem)] font-extrabold leading-[1.05] tracking-tight">App controls live here now.</h1>
    <p class="mt-4 text-ink-dim">Providers, tools, loops, and notification setup.</p>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <a class="card grid gap-3 no-underline transition-colors hover:border-edge-strong" href="/providers">
      <div class="flex items-center gap-3">
        <span class="grid size-9 place-items-center rounded-xl bg-accent/15 text-accent">
          <%~ include('./partials/icon', { name: 'cube', class: 'size-4' }) %>
        </span>
        <h2 class="text-lg font-bold">Providers</h2>
      </div>
      <p class="mb-0 text-sm text-ink-dim">Models, endpoint URLs, API keys, Codex OAuth, and provider defaults.</p>
    </a>

    <a class="card grid gap-3 no-underline transition-colors hover:border-edge-strong" href="/mcp-servers">
      <div class="flex items-center gap-3">
        <span class="grid size-9 place-items-center rounded-xl bg-accent/15 text-accent">
          <%~ include('./partials/icon', { name: 'wrench', class: 'size-4' }) %>
        </span>
        <h2 class="text-lg font-bold">MCP servers</h2>
      </div>
      <p class="mb-0 text-sm text-ink-dim">Register tool servers, then enable them per conversation or loop.</p>
    </a>

    <a class="card grid gap-3 no-underline transition-colors hover:border-edge-strong" href="/loops">
      <div class="flex items-center gap-3">
        <span class="grid size-9 place-items-center rounded-xl bg-accent/15 text-accent">
          <%~ include('./partials/icon', { name: 'clock', class: 'size-4' }) %>
        </span>
        <h2 class="text-lg font-bold">Loops</h2>
      </div>
      <p class="mb-0 text-sm text-ink-dim">Recurring prompt/tool runs with manual run, schedules, and unattended tool approvals.</p>
    </a>

    <div class="card grid gap-3 border-dashed opacity-80">
      <div class="flex items-center gap-3">
        <span class="grid size-9 place-items-center rounded-xl bg-ink/5 text-ink-dim">
          <%~ include('./partials/icon', { name: 'sliders', class: 'size-4' }) %>
        </span>
        <div class="min-w-0">
          <h2 class="text-lg font-bold">Prompts & defaults</h2>
          <p class="mb-0 text-xs font-semibold tracking-wider text-ink-faint uppercase">Coming soon</p>
        </div>
      </div>
      <p class="mb-0 text-sm text-ink-dim">System prompt presets, naming behavior, model knobs, and slow/local-LLM-friendly automation.</p>
    </div>
  </div>

  <section id="regional" class="card grid gap-4 scroll-mt-24">
    <div>
      <h2 class="text-xl font-bold">Time &amp; region</h2>
      <p class="mb-0 text-sm text-ink-dim">Loops use this timezone when you create them. Existing loops keep their saved timezone so their timing never changes silently.</p>
    </div>
    <% if (it.timeZoneSaved) { %><div class="alert-ok" role="status"><p class="mb-0">Timezone saved.</p></div><% } %>
    <% if (it.timeZoneError) { %><div class="alert-danger" role="alert"><p class="mb-0">Enter a valid IANA timezone, such as America/New_York.</p></div><% } %>
    <form class="grid max-w-md gap-3" method="post" action="/settings/timezone">
      <label class="grid gap-1.5">
        <span>Timezone</span>
        <input class="input" name="timezone" value="<%= it.timeZone %>" list="timezone-options" autocomplete="off" required>
        <span class="text-xs text-ink-faint">Use an IANA name. Daylight-saving changes are handled automatically.</span>
      </label>
      <datalist id="timezone-options">
        <% ;['UTC','America/Los_Angeles','America/Denver','America/Chicago','America/New_York','America/Toronto','America/Sao_Paulo','Europe/London','Europe/Paris','Europe/Berlin','Africa/Johannesburg','Asia/Dubai','Asia/Kolkata','Asia/Singapore','Asia/Tokyo','Australia/Sydney','Pacific/Auckland'].forEach((zone) => { %><option value="<%= zone %>"></option><% }) %>
      </datalist>
      <button class="btn btn-primary justify-self-start" type="submit">Save timezone</button>
    </form>
  </section>

  <section id="notifications" class="card grid gap-4 scroll-mt-24" data-push-settings data-vapid-public-key="<%= it.vapidPublicKey || '' %>">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <h2 class="text-xl font-bold">Notifications</h2>
        <p class="mb-0 text-sm text-ink-dim">Loop notifications open the finished chat for now. Artifact-specific notification targets can come later.</p>
      </div>
      <span class="chip"><%= it.pushSubscriptionCount %> device<%= it.pushSubscriptionCount === 1 ? '' : 's' %></span>
    </div>

    <% if (it.pushTestSent) { %>
      <div class="rounded-2xl border border-accent/30 bg-accent/10 p-4 text-sm text-accent" role="status">
        <p class="mb-0">Test notification sent to every subscribed device.</p>
      </div>
    <% } %>

    <% if (!it.pushConfigured) { %>
      <div class="alert-danger" role="alert">
        <p class="mb-0">Push is not configured on this server. Set <code>VAPID_PUBLIC_KEY</code> and <code>VAPID_PRIVATE_KEY</code> (generate with <code>npx web-push generate-vapid-keys</code> or <code>bunx web-push generate-vapid-keys</code>).</p>
      </div>
    <% } %>

    <div class="hidden rounded-2xl border border-warn/30 bg-warn/10 p-4" data-ios-install>
      <h3 class="font-bold">iPhone/iPad setup: install inkcap first</h3>
      <ol class="mt-2 grid list-decimal gap-1 pl-5 text-sm text-ink-dim">
        <li>Open this page in Safari.</li>
        <li>Tap Share.</li>
        <li>Tap <strong>Add to Home Screen</strong>.</li>
        <li>Open inkcap from the new Home Screen icon and log in again.</li>
        <li>Come back here and press Enable notifications.</li>
      </ol>
      <p class="mb-0 mt-2 text-xs text-ink-faint">iOS only allows Web Push for installed Home Screen web apps.</p>
    </div>

    <form method="post" action="/settings/notification-policy" class="grid gap-2 border-y border-edge py-4">
      <label class="text-sm font-semibold" for="loop_notification_prompt">When should completed loops notify me?</label>
      <textarea id="loop_notification_prompt" name="loop_notification_prompt" class="input min-h-28" maxlength="4000" required><%= it.loopNotificationPrompt %></textarea>
      <p class="mb-0 text-xs text-ink-faint">After a successful loop, its model considers the completed chat and this app-wide guidance. Failures and approval requests always notify.</p>
      <% if (it.notificationPolicySaved) { %><p class="mb-0 text-sm text-accent" role="status">Notification guidance saved.</p><% } %>
      <% if (it.notificationPolicyError) { %><p class="mb-0 text-sm text-danger" role="alert">Enter notification guidance between 1 and 4,000 characters.</p><% } %>
      <button class="btn btn-ghost justify-self-start" type="submit">Save notification guidance</button>
    </form>

    <div class="grid gap-2 text-sm text-ink-dim" data-push-status>
      <p class="mb-0">Status: <span data-push-status-text>Checking browser support…</span></p>
    </div>

    <div class="flex flex-wrap gap-2">
      <button class="btn btn-primary" type="button" data-push-enable <%= it.pushConfigured ? '' : 'disabled' %>>Enable notifications on this device</button>
      <button class="btn btn-ghost" type="button" data-push-disable>Disable on this device</button>
    </div>

    <form method="post" action="/push/test" class="flex flex-wrap items-center gap-3 border-t border-edge pt-4">
      <button class="btn btn-ghost" type="submit" <%= it.pushConfigured && it.pushSubscriptionCount > 0 ? '' : 'disabled' %>>Send test notification</button>
      <p class="mb-0 text-xs text-ink-faint">Useful after installing to Home Screen or changing browser permissions.</p>
    </form>
  </section>
</section>

<script src="/assets/<%= it.assetVersion %>/notifications.js" defer></script>
