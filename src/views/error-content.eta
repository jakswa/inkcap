<section class="card mx-auto max-w-2xl p-8 text-center">
  <p class="eyebrow mb-3">Error <%= it.status %></p>
  <h1 class="text-[clamp(2rem,5vw,3rem)] font-extrabold leading-none tracking-tight"><%= it.title %></h1>
  <p class="mt-4 text-ink-dim"><%= it.message %></p>
  <a class="mt-6 btn btn-primary" href="/">Go home</a>
</section>
