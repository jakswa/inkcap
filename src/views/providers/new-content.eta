<section class="grid grid-cols-[minmax(0,1fr)_minmax(18rem,25rem)] items-start gap-[clamp(1.5rem,6vw,4rem)] max-[720px]:grid-cols-1">
  <div>
    <p class="eyebrow mb-3">Registry</p>
    <h1 class="max-w-[13ch] text-[clamp(2rem,5vw,3.25rem)] font-extrabold leading-[1.05] tracking-tight">Add provider</h1>
    <p class="mt-4 text-ink-dim">Register a llama-server or OpenAI-compatible endpoint. Saving runs model discovery and a tiny text inference first.</p>

    <form class="card mt-6 grid max-w-[25rem] gap-3" method="post" action="/providers/codex/connect">
      <p class="mb-0 font-bold">ChatGPT subscription (Codex)</p>
      <p class="mb-0 text-sm text-ink-dim">
        Use your own ChatGPT plan via the Codex CLI's OAuth flow. Your browser
        signs in at auth.openai.com and returns to <code>localhost:1455</code>,
        so run spail on the machine you're browsing from.
      </p>
      <label class="grid gap-1.5">
        <span>Name</span>
        <input class="input" name="name" maxlength="200" value="ChatGPT Codex">
      </label>
      <button class="btn btn-primary" type="submit">Sign in with ChatGPT</button>
      <p class="mb-0 text-xs text-ink-faint">
        Personal-use tooling: this talks to an undocumented ChatGPT backend
        that may change without notice. Usage counts against your plan's
        rolling limits.
      </p>
    </form>
  </div>

  <form class="card grid gap-4" method="post" action="/providers">
    <% if (it.errors.length > 0) { %>
      <div class="alert-danger" role="alert">
        <% it.errors.forEach((error) => { %>
          <p class="last:mb-0"><%= error %></p>
        <% }) %>
      </div>
    <% } %>

    <label class="grid gap-1.5">
      <span>Name</span>
      <input class="input" name="name" maxlength="200" value="<%= it.values.name || '' %>" required>
    </label>

    <label class="grid gap-1.5">
      <span>Kind</span>
      <select class="input" name="kind" required>
        <option value="llama-server" <%= it.values.kind === 'llama-server' ? 'selected' : '' %>>llama-server</option>
        <option value="openai-compat" <%= it.values.kind === 'openai-compat' ? 'selected' : '' %>>openai-compat</option>
      </select>
    </label>

    <label class="grid gap-1.5">
      <span>Base URL</span>
      <input class="input" name="base_url" placeholder="http://localhost:8001" maxlength="2048" value="<%= it.values.baseUrl || '' %>" required>
    </label>

    <label class="grid gap-1.5">
      <span>API key</span>
      <input class="input" name="api_key" type="password" autocomplete="off" value="<%= it.values.apiKey || '' %>">
    </label>

    <label class="grid gap-1.5">
      <span>Default model</span>
      <input class="input" name="default_model" maxlength="200" list="provider-models" value="<%= it.values.defaultModel || '' %>" placeholder="Auto-filled from the test when blank">
    </label>

    <label class="grid gap-1.5">
      <span>Available models <span class="text-ink-faint">(one per line or comma-separated)</span></span>
      <textarea class="input font-mono text-sm" name="models" rows="5" placeholder="Leave blank to use discovered models"><%= it.values.modelsText || '' %></textarea>
    </label>

    <datalist id="provider-models">
      <% ;(it.values.modelsText || '').split(/[\n,]/).map((model) => model.trim()).filter(Boolean).forEach((model) => { %>
        <option value="<%= model %>"></option>
      <% }) %>
    </datalist>

    <% if (it.testResult) { %>
      <% if (it.testResult.ok) { %>
        <div class="alert-ok" role="status">
          <p class="mb-0 font-bold">Provider test passed</p>
          <p class="mb-0">Inference<% if (it.testResult.inferenceModel) { %> on <%= it.testResult.inferenceModel %><% } %>: <%= it.testResult.inferenceText %></p>
        </div>
      <% } else if (it.testResult.models && it.testResult.models.length > 0) { %>
        <div class="alert-danger" role="alert">
          <p class="mb-0 font-bold">Inference failed after model discovery</p>
          <p class="mb-0">Discovered models were copied into the list so you can pick one and retry.</p>
        </div>
      <% } %>
    <% } %>

    <button class="btn btn-primary" type="submit">Test and add provider</button>
    <p class="mb-0 text-ink-dim"><a class="link" href="/providers">Back to providers</a></p>
  </form>
</section>
