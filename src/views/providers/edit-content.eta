<section class="grid grid-cols-[minmax(0,1fr)_minmax(18rem,25rem)] items-start gap-[clamp(1.5rem,6vw,4rem)] max-[720px]:grid-cols-1">
  <div>
    <p class="eyebrow mb-3">Registry</p>
    <h1 class="max-w-[13ch] text-[clamp(2rem,5vw,3.25rem)] font-extrabold leading-[1.05] tracking-tight">Edit provider</h1>
    <% if (it.provider.kind === 'openai-codex') { %>
      <p class="mt-4 text-ink-dim">
        ChatGPT OAuth: <strong><%= it.provider.oauthConnected ? 'connected' : 'not connected' %></strong>
        <% if (it.provider.oauthAccountId) { %>
          &middot; account <code class="text-sm"><%= it.provider.oauthAccountId %></code>
        <% } %>
      </p>
      <div class="alert-warn mt-4" role="note">
        <p class="mb-0">
          <strong>Codex caveat:</strong> not the official API; may break or hit
          ChatGPT limits. Re-auth uses a one-time OpenAI device code. OpenAI
          handles your password; inkcap stores refreshable tokens server-side.
        </p>
      </div>
      <form class="mt-4" method="post" action="/providers/<%= it.provider.id %>/reauth">
        <button class="btn btn-ghost" type="submit">Re-authenticate with ChatGPT</button>
      </form>
      <form class="mt-3" method="post" action="/providers/<%= it.provider.id %>/reauth/localhost">
        <button class="link text-sm" type="submit">Device code unavailable? Use legacy localhost callback.</button>
      </form>
    <% } else { %>
      <p class="mt-4 text-ink-dim">Stored API key: <strong><%= it.provider.maskedApiKey %></strong></p>
    <% } %>
  </div>

  <form class="card grid gap-4" method="post" action="/providers/<%= it.provider.id %>">
    <% if (it.errors.length > 0) { %>
      <div class="alert-danger" role="alert">
        <% it.errors.forEach((error) => { %>
          <p class="last:mb-0"><%= error %></p>
        <% }) %>
      </div>
    <% } %>

    <label class="grid gap-1.5">
      <span>Name</span>
      <input class="input" name="name" maxlength="200" value="<%= it.values.name || '' %>" required>
    </label>

    <% if (it.provider.kind === 'openai-codex') { %>
      <input type="hidden" name="kind" value="openai-codex">
      <div class="grid gap-1.5">
        <span>Kind</span>
        <p class="mb-0 text-ink-dim">openai-codex (ChatGPT subscription OAuth)</p>
      </div>
    <% } else { %>
      <label class="grid gap-1.5">
        <span>Connection type</span>
        <select class="input" name="kind" required>
          <option value="llama-server" <%= it.values.kind === 'llama-server' ? 'selected' : '' %>>Local llama-server</option>
          <option value="openai-compat" <%= it.values.kind === 'openai-compat' ? 'selected' : '' %>>Hosted or local OpenAI-compatible API</option>
        </select>
      </label>
    <% } %>

    <label class="grid gap-1.5">
      <span>Endpoint URL</span>
      <input class="input" name="base_url" maxlength="2048" value="<%= it.values.baseUrl || '' %>" required>
    </label>

    <% if (it.provider.kind !== 'openai-codex') { %>
      <label class="grid gap-1.5">
        <span>New API key</span>
        <input class="input" name="api_key" type="password" autocomplete="off" placeholder="Leave blank to keep the current key" value="<%= it.values.apiKey || '' %>">
      </label>

      <label class="flex items-center gap-2">
        <input type="checkbox" name="clear_api_key" <%= it.values.clearApiKey ? 'checked' : '' %>>
        <span>Clear the stored API key</span>
      </label>
    <% } %>

    <%
      const enabledModels = new Set((it.values.modelsText || '').split(/[\n,]/).map((model) => model.trim()).filter(Boolean))
      const discoveredModels = it.discoveredModels === null ? null : new Set(it.discoveredModels || [])
    %>
    <div class="grid gap-2">
      <input type="hidden" name="models_present" value="1">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <span class="font-semibold">Models available to chats</span>
          <p class="mb-0 text-xs text-ink-faint">You decide what changes. Refresh compares the saved catalog with the provider; it does not update anything until you save.</p>
        </div>
        <button class="btn btn-ghost" type="submit" formaction="/providers/<%= it.provider.id %>/discover" formmethod="post">Refresh model catalog</button>
      </div>
      <% if (it.availableModels.length === 0) { %>
        <div class="rounded-xl border border-dashed border-edge p-4 text-sm text-ink-faint">No models stored. Refresh discovery, or add a model the endpoint does not report.</div>
      <% } else { %>
        <div class="scroll-thin grid max-h-72 gap-1 overflow-y-auto rounded-xl border border-edge p-2">
          <% it.availableModels.forEach((model) => { const reported = discoveredModels?.has(model) %>
            <label class="flex min-w-0 items-start gap-3 rounded-lg px-2 py-2 hover:bg-ink/5">
              <input class="mt-1" type="checkbox" name="models" value="<%= model %>" <%= enabledModels.has(model) ? 'checked' : '' %>>
              <span class="min-w-0 flex-1"><strong class="block break-all font-mono text-sm"><%= model %></strong><% if (discoveredModels !== null) { %><span class="text-xs <%= reported ? 'text-ink-faint' : 'text-warn' %>"><%= reported ? 'Reported by provider now' : 'Not reported now — uncheck to retire' %></span><% } %></span>
            </label>
          <% }) %>
        </div>
      <% } %>
      <details class="text-sm">
        <summary class="link cursor-pointer">Provider does not report a model?</summary>
        <label class="mt-2 grid gap-1.5"><span>Add its exact model ID when saving</span><input class="input font-mono" name="custom_model" maxlength="200" placeholder="model-id"></label>
      </details>
    </div>

    <label class="grid gap-1.5">
      <span>Default model</span>
      <select class="input" name="default_model">
        <option value="">No explicit default</option>
        <% it.availableModels.forEach((model) => { %><option value="<%= model %>" <%= it.values.defaultModel === model ? 'selected' : '' %>><%= model %></option><% }) %>
      </select>
      <span class="text-xs text-ink-faint">The exact selected ID is sent; inkcap never substitutes another model.</span>
    </label>

    <% if (it.testResult) { %>
      <% if (it.testResult.ok) { %>
        <div class="alert-ok" role="status">
          <p class="mb-0 font-bold">Provider test passed</p>
          <p class="mb-0">Inference<% if (it.testResult.inferenceModel) { %> on <%= it.testResult.inferenceModel %><% } %>: <%= it.testResult.inferenceText %></p>
        </div>
      <% } else if (it.testResult.models && it.testResult.models.length > 0) { %>
        <div class="alert-danger" role="alert">
          <p class="mb-0 font-bold">Inference failed after model discovery</p>
          <p class="mb-0">Discovered models: <%= it.testResult.models.join(', ') %></p>
        </div>
      <% } %>
    <% } %>

    <button class="btn btn-primary" type="submit">Test connection and save</button>
    <p class="mb-0 text-ink-dim"><a class="link" href="/providers">Back to providers</a></p>
  </form>
</section>
