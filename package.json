{
  "name": "spail",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun src/dev.ts",
    "css:build": "tailwindcss -i ./src/static/app.tailwind.css -o ./src/static/app.css --minify",
    "css:watch": "tailwindcss -i ./src/static/app.tailwind.css -o ./src/static/app.css --watch",
    "start": "bun run css:build && bun src/index.ts",
    "start:prod": "bun build/index.js",
    "db:migrate": "bun src/tasks/migrate.ts",
    "db:types": "bun bun-sqlgen generate 'src/**/*.ts' --migrations src/db/migrations --out src/db/queries/queries.gen.d.ts",
    "typecheck": "tsc --noEmit",
    "app:build": "bun run css:build && bun src/build.ts",
    "build": "bun run db:types && bun run typecheck && bun test && bun run app:build"
  },
  "dependencies": {
    "eta": "^3.5.0",
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@ilbertt/bun-sqlgen": "^0.3.1",
    "@tailwindcss/cli": "^4.3.2",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
