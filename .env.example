DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inkcap"
SESSION_SECRET="change-me-in-production"
ASSET_VERSION="dev"
PORT=3000
NODE_ENV=development
# Self-serve registration: "open" or "closed". Defaults to open in
# development and closed in production; closed deployments bootstrap with
# `bun build/tasks/create-user.js`.
REGISTRATION=open

# Split-origin deployments (TLS-terminating proxy and/or direct LAN IP
# access), all optional:
# PUBLIC_ORIGIN: the canonical browser-facing origin. Used for OAuth return
# redirects and trusted as a CSRF origin — set it when TLS terminates at a
# proxy, so the browser's https origin differs from what the server sees.
#PUBLIC_ORIGIN=https://chat.example.com
# CSRF_TRUSTED_ORIGINS: extra origins allowed to submit forms,
# comma-separated (e.g. a LAN IP used to avoid hairpin NAT). Listing a
# plain-http origin also opts production into issuing/accepting the insecure
# `session` cookie for http logins (docs/issues/18).
#CSRF_TRUSTED_ORIGINS=http://192.168.1.160
# OUTBOUND_TRUSTED_HOSTS: provider/MCP hosts exempt from the production
# https-only + no-private-address outbound guard, comma-separated (e.g. a
# llama-server on the LAN).
#OUTBOUND_TRUSTED_HOSTS=192.168.1.169

# --- Operational knobs (read via process.env, all optional) ---------------
# PROVIDER_STALL_TIMEOUT_MS: how long a provider stream may go silent before
# the watchdog parks the run as errored. Default is set in the runner; raise
# it for slow local models that pause between tokens.
#PROVIDER_STALL_TIMEOUT_MS=120000

# CODEX_OAUTH_PORT: loopback port for the "Sign in with ChatGPT" callback.
# Defaults to 1455 (what the Codex CLI expects); change only if that port is
# taken and you can tunnel the alternate.
#CODEX_OAUTH_PORT=1455

# DEV_LLAMA_SERVER / DEV_LLAMA_KEY: base URL + key the seed-provider task uses
# to create a llama-server provider (bun src/tasks/seed-provider.ts).
#DEV_LLAMA_SERVER=http://192.168.1.169:8080
#DEV_LLAMA_KEY=
